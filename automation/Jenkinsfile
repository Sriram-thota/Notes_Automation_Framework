pipeline {
    agent any

    environment {
        PROJECT_DIR = 'C:\\Capgemini\\Notes_Automation_Framework\\automation'
    }

    stages {
        stage('Checkout SCM') {
            steps {
                echo 'Code ready'
            }
        }

        stage('Run API Tests') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    bat "cd %PROJECT_DIR% && venv\\Scripts\\pytest.exe tests/api -n 2 --alluredir=allure-results -v"
                }
            }
        }

        stage('Run UI Tests') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    bat "cd %PROJECT_DIR% && venv\\Scripts\\pytest.exe tests/ui -n 2 --alluredir=allure-results -v"
                }
            }
        }

        stage('Run Hybrid E2E Tests') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    bat "cd %PROJECT_DIR% && venv\\Scripts\\pytest.exe tests/e2e --alluredir=allure-results -v"
                }
            }
        }

        stage('Generate Allure Report') {
            steps {
                allure(
                    includeProperties: false,
                    jdk: '',
                    results: [[path: 'C:\\Capgemini\\Notes_Automation_Framework\\automation\\allure-results']]
                )
            }
        }
    }

    post {
        always {
            archiveArtifacts(
                artifacts: 'C:\\Capgemini\\Notes_Automation_Framework\\automation\\screenshots\\*.png',
                allowEmptyArchive: true
            )
        }
        success {
            echo 'Pipeline executed successfully.'
        }
        unstable {
            echo 'Some test cases failed. Build marked as UNSTABLE.'
        }
        failure {
            echo 'Pipeline execution failed.'
        }
    }
}